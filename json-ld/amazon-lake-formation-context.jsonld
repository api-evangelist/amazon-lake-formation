{
  "@context": {
    "@vocab": "https://schema.org/",
    "lf": "https://docs.aws.amazon.com/lake-formation/latest/APIReference/",
    "aws": "https://aws.amazon.com/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",

    "Permission": {
      "@id": "lf:API_ListPermissions",
      "@context": {
        "principal": {
          "@id": "lf:dataLakePrincipal",
          "@type": "lf:DataLakePrincipal"
        },
        "resource": {
          "@id": "lf:permissionResource",
          "@type": "lf:Resource"
        },
        "permissions": {
          "@id": "lf:permissions",
          "@container": "@list"
        },
        "permissionsWithGrantOption": {
          "@id": "lf:permissionsWithGrantOption",
          "@container": "@list"
        }
      }
    },

    "DataLakePrincipal": {
      "@id": "lf:DataLakePrincipal",
      "@context": {
        "dataLakePrincipalIdentifier": {
          "@id": "schema:identifier",
          "@type": "xsd:string"
        }
      }
    },

    "Resource": {
      "@id": "lf:Resource",
      "@context": {
        "database": {
          "@id": "lf:databaseResource",
          "@type": "lf:DatabaseResource"
        },
        "table": {
          "@id": "lf:tableResource",
          "@type": "lf:TableResource"
        },
        "tableWithColumns": {
          "@id": "lf:tableWithColumnsResource",
          "@type": "lf:TableWithColumnsResource"
        },
        "dataLocation": {
          "@id": "lf:dataLocationResource",
          "@type": "lf:DataLocationResource"
        },
        "lfTag": {
          "@id": "lf:lfTagResource",
          "@type": "lf:LFTagResource"
        }
      }
    },

    "DatabaseResource": {
      "@id": "lf:DatabaseResource",
      "@context": {
        "catalogId": {
          "@id": "lf:catalogId",
          "@type": "xsd:string"
        },
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        }
      }
    },

    "TableResource": {
      "@id": "lf:TableResource",
      "@context": {
        "catalogId": {
          "@id": "lf:catalogId",
          "@type": "xsd:string"
        },
        "databaseName": {
          "@id": "lf:databaseName",
          "@type": "xsd:string"
        },
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        }
      }
    },

    "DataLocationResource": {
      "@id": "lf:DataLocationResource",
      "@context": {
        "catalogId": {
          "@id": "lf:catalogId",
          "@type": "xsd:string"
        },
        "resourceArn": {
          "@id": "schema:identifier",
          "@type": "xsd:string"
        }
      }
    },

    "LFTag": {
      "@id": "lf:API_GetLFTag",
      "@context": {
        "catalogId": {
          "@id": "lf:catalogId",
          "@type": "xsd:string"
        },
        "tagKey": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "tagValues": {
          "@id": "lf:tagValues",
          "@container": "@list"
        }
      }
    },

    "DataLakeSettings": {
      "@id": "lf:API_GetDataLakeSettings",
      "@context": {
        "dataLakeAdmins": {
          "@id": "lf:dataLakeAdmins",
          "@container": "@list"
        },
        "createDatabaseDefaultPermissions": {
          "@id": "lf:createDatabaseDefaultPermissions",
          "@container": "@list"
        },
        "createTableDefaultPermissions": {
          "@id": "lf:createTableDefaultPermissions",
          "@container": "@list"
        },
        "trustedResourceOwners": {
          "@id": "lf:trustedResourceOwners",
          "@container": "@list"
        }
      }
    }
  }
}
